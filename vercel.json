{
  "version": 2,
  "rewrites": [
    {
      "source": "/api/(.*)",
      "destination": "/api/index.js"
    },
    {
      "source": "/download",
      "destination": "/api/index.js"
    },
    {
      "source": "/((?!assets|favicon.ico|api|download).*)",
      "destination": "/index.html"
    }
  ]
}